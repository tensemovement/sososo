# 환경변수를 추가할 때 이 템플릿에 키를 기록하고,
# 실제 값은 .env.local 에만 작성한다 (.env.local 은 git 에 커밋하지 않는다).

# ── App (public) ──────────────────────────────────────────────
# 사이트 절대 URL (OG metadata, 절대 링크에 사용)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ── 업로드 (수집 Routine / Vercel) ───────────────────────────
# Routine 환경에 설정: 배포된 업로드 엔드포인트와 인증 토큰
UPLOAD_URL="https://sososo.example.com/api/upload"
# `openssl rand -hex 32` 로 생성. Vercel 시크릿의 UPLOAD_TOKEN 과 동일 값
UPLOAD_TOKEN=""

# ── S3 (서버 전용 / Vercel 시크릿) ───────────────────────────
# 아래 값은 Vercel 대시보드에만 설정. Routine 환경에는 넣지 않는다.
AWS_REGION="ap-northeast-2"
S3_BUCKET=""
S3_KEY="sososo/news.json"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
